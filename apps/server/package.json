{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc --noEmit",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "portless run --force",
		"dev:app": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs"
	},
	"portless": {
		"name": "api.visp",
		"script": "dev:app",
		"appPort": 3000
	},
	"dependencies": {
		"@VISP/api": "workspace:*",
		"@VISP/auth": "workspace:*",
		"@VISP/db": "workspace:*",
		"@VISP/env": "workspace:*",
		"@elysiajs/cors": "^1.4.2",
		"@elysiajs/trpc": "^1.1.0",
		"@hono/trpc-server": "^0.4.2",
		"@sinclair/typebox": "^0.34.49",
		"@trpc/server": "catalog:",
		"ai": "^6.0.0",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"elysia": "catalog:",
		"evlog": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@VISP/config": "workspace:*",
		"@types/bun": "catalog:",
		"drizzle-orm": "^0.45.2",
		"tsdown": "^0.22.3",
		"typescript": "catalog:",
		"unrun": "^0.3.1"
	}
}
