http://relay.visp.localhost {
	@ping path /ping
	header @ping Access-Control-Allow-Origin "https://visp.localhost"
	header @ping Access-Control-Allow-Methods "GET, OPTIONS"
	header @ping Cache-Control "no-store"
	respond @ping 204
	reverse_proxy mediamtx:8889
}

